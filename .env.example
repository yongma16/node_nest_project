# AI 通用配置
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=your_openai_api_key_here
AI_MODEL=gpt-4o-mini
AI_TIMEOUT_MS=60000

# Kimi API 配置
KIMI_API_KEY=your_kimi_api_key_here
KIMI_TIMEOUT_MS=60000

# StepFun API 配置
STEP_BASE_URL=https://api.stepfun.com/v1
STEP_API_KEY=your_step_api_key_here
STEP_MODEL=step-1-8k
STEP_IMAGE_EDIT_MODEL=step-1x-edit
STEP_IMAGE_MODEL=step-1x-medium
STEP_TIMEOUT_MS=60000

# 应用配置
PORT=5555
HOST=0.0.0.0
NODE_ENV=development

# MySQL 配置
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=ai_proxy
MYSQL_SYNCHRONIZE=true